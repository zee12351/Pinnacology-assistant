+
+/* =====================================================================
+   LIGHT THEME OVERRIDES
+   The app's chrome is built with hardcoded dark hex utilities. next-themes
+   adds `.light` on <html> when the Light theme is chosen. Here we remap the
+   NEUTRAL dark surfaces / borders / text to a light palette. Brand accent
+   colors (purples/blues/red) are intentionally left untouched so colored
+   buttons keep white text. The white document paper (bg-white/text-black) is
+   also left untouched so documents look identical in both themes.
+   ===================================================================== */
+
+/* ---- Neutral background surfaces (dark -> light) ---- */
+html.light .bg-\[\#0a0a0a\],
+html.light .bg-\[\#111\],
+html.light .bg-\[\#111111\] { background-color: #f6f7f9 !important; }
+html.light .bg-\[\#151515\],
+html.light .bg-\[\#161616\] { background-color: #f0f2f5 !important; }
+html.light .bg-\[\#1a1a1a\],
+html.light .bg-\[\#1e1e1e\],
+html.light .bg-\[\#252525\] { background-color: #ffffff !important; }
+html.light .bg-\[\#222\] { background-color: #eef0f3 !important; }
+html.light .bg-\[\#2a2a2a\],
+html.light .bg-\[\#2d2d2d\] { background-color: #e8ebef !important; }
+html.light .bg-\[\#333\] { background-color: #e1e5ea !important; }
+html.light .bg-\[\#3d3d3d\] { background-color: #d6dae0 !important; }
+html.light .bg-\[\#4d4d4d\] { background-color: #cbd0d7 !important; }
+html.light .bg-\[\#555\] { background-color: #c1c7cf !important; }
+
+/* ---- Dark-blue neutral panels -> pale blue tints ---- */
+html.light .bg-\[\#1b1c3a\],
+html.light .bg-\[\#292a4a\] { background-color: #ebedf8 !important; }
+html.light .bg-\[\#293b6e\],
+html.light .bg-\[\#344a8a\] { background-color: #e3eafb !important; }
+
+/* ---- Borders (dark -> light) ---- */
+html.light .border-\[\#222\] { border-color: #e5e7eb !important; }
+html.light .border-\[\#2a2a2a\] { border-color: #e2e5e9 !important; }
+html.light .border-\[\#333\] { border-color: #d9dde2 !important; }
+html.light .border-\[\#3d3d3d\] { border-color: #d0d4da !important; }
+html.light .border-\[\#444\] { border-color: #cbd0d6 !important; }
+html.light .border-\[\#555\] { border-color: #bcc2ca !important; }
+html.light .border-\[\#3b3c6a\],
+html.light .border-\[\#2a2b4a\] { border-color: #c9d2ea !important; }
+
+/* ---- Text: dark-theme assumes light text; flip neutrals to dark ---- */
+html.light .text-white { color: #111827 !important; }
+html.light .text-gray-100,
+html.light .text-gray-200 { color: #1f2937 !important; }
+html.light .text-gray-300 { color: #374151 !important; }
+html.light .text-gray-400 { color: #4b5563 !important; }
+html.light .text-gray-500 { color: #6b7280 !important; }
+html.light .text-\[\#888\] { color: #6b7280 !important; }
+/* link / accent text: darken for contrast on light */
+html.light .text-\[\#6d93e8\] { color: #2f5bd0 !important; }
+html.light .text-\[\#7d84ff\] { color: #4046d6 !important; }
+html.light .text-\[\#7fa3ff\] { color: #3f6fd6 !important; }
+
+/* ---- Brand surfaces stay as-is: force their text/icons white ---- */
+html.light :is(
+  .bg-\[\#5b5fff\], .bg-\[\#6b6fff\], .bg-\[\#5259c9\], .bg-\[\#464eb8\],
+  .bg-\[\#6d93e8\], .bg-\[\#2b579a\], .bg-\[\#9b0000\]
+),
+html.light :is(
+  .bg-\[\#5b5fff\], .bg-\[\#6b6fff\], .bg-\[\#5259c9\], .bg-\[\#464eb8\],
+  .bg-\[\#6d93e8\], .bg-\[\#2b579a\], .bg-\[\#9b0000\]
+) * {
+  color: #ffffff !important;
+}
+
+/* page backdrop */
+html.light body { background-color: #f6f7f9; }
