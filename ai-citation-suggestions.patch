+  const findClaimInsertPos = (claim: string): number | null => {
+    if (!editor) return null;
+    const target = (claim || '').trim();
+    if (!target) return null;
+    let result: number | null = null;
+    editor.state.doc.descendants((node: any, pos: number) => {
