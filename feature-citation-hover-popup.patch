-                      </div>
-                   </div>
-                   <div className="px-4 py-3 bg-[#1e1e1e] border-t border-[#333] flex justify-between items-center">
-                     <div className="flex gap-2">
-                       <button className="bg-[#5b5fff] hover:bg-[#6b6fff] text-white px-4 py-1.5 rounded-lg text-[13px] font-bold flex items-center gap-2 transition-colors">
-                         Accept <ChevronRight className="w-3.5 h-3.5" />
-                       </button>
-                       <button className="border border-[#444] hover:bg-[#2a2a2a] text-white px-4 py-1.5 rounded-lg text-[13px] font-bold flex items-center gap-2 transition-colors">
-                         <Sparkles className="w-3.5 h-3.5" /> Refine suggestion
-                       </button>
-                     </div>
-                     <div className="flex gap-2 text-gray-400">
-                       <ThumbsUp className="w-4 h-4 cursor-pointer hover:text-white" />
-                       <ThumbsDown className="w-4 h-4 cursor-pointer hover:text-white" />
-                     </div>
+                      {citationMeta.loading ? (
+                        <div className="flex items-center gap-2 text-gray-400 text-[13px] py-2">
+                          <Loader2 className="w-4 h-4 animate-spin" /> Looking up citation…
+                        </div>
+                      ) : citationMeta.data ? (
+                        <>
+                          <h3 className="text-[15px] font-bold text-white leading-snug">
+                            {citationMeta.data.title || citationPopup.text}
+                          </h3>
+                          {citationMeta.data.authors && (
+                            <p className="text-[13px] text-gray-400">{citationMeta.data.authors}</p>
+                          )}
+                          {citationMeta.data.container && (
+                            <p className="text-[13px] text-[#10b981]">
+                              {citationMeta.data.container}
+                              {citationMeta.data.year && <span className="text-gray-500"> • {citationMeta.data.year}</span>}
+                            </p>
+                          )}
+                          {citationMeta.data.abstract && (
+                            <div className="mt-1 bg-[#333]/50 rounded-lg p-3 text-[13px] text-gray-300 leading-relaxed border-l-2 border-[#5b5fff] max-h-32 overflow-y-auto">
+                              {citationMeta.data.abstract}{citationMeta.data.truncated ? '…' : ''}
+                            </div>
+                          )}
+                          {citationMeta.data.url && (
+                            <a
+                              href={citationMeta.data.url}
+                              target="_blank"
+                              rel="noreferrer"
+                              className="mt-1 flex items-center gap-1 text-[13px] font-bold text-gray-300 hover:text-white w-fit"
+                            >
+                              <ChevronUp className="w-4 h-4 rotate-45" /> View source
+                            </a>
+                          )}
+                        </>
+                      ) : (
